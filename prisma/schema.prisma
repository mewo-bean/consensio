// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int                   @id @default(autoincrement())
  first_name       String?                @db.VarChar(20) //пока сделал необязательными, надо обсудить
  last_name        String?                @db.VarChar(20)
  username         String                @unique @db.VarChar(50)
  email            String                @unique @db.VarChar(255)
  password_hash    String                @db.VarChar(255)
  //salt             String                @db.VarChar(255)
  tg_id            Int?
  survey_results   SurveyResult[]
  complaints_from  Complaint[]           @relation("from_user")
  complaints_to    Complaint[]           @relation("to_user")
  notification_settings NotificationSettings?
  web_push_subscriptions WebPushSubscription?
  teams            UserTeam[]

  @@map("users")
}

model Team {
  id            Int           @id @default(autoincrement())
  title         String        @db.VarChar(50)
  team_surveys  TeamSurvey[]
  complaints    Complaint[]
  members       UserTeam[]

  @@map("teams")
}

model SampleSurvey {
  id            Int            @id @default(autoincrement())
  title         String         @db.VarChar(50)
  team_surveys  TeamSurvey[]
  survey_results SurveyResult[]
  questions     Question[]

  @@map("sample_surveys")
}

model Subscale {
  id          Int                 @id @default(autoincrement())
  title       String              @db.VarChar(50)
  top_mean    Int                 @db.SmallInt
  bottom_mean Int                 @db.SmallInt
  questions   QuestionSubscale[]
  scores      UserSubscaleScore[]

  @@map("subscales")
}

model TeamSurvey {
  id              Int            @id @default(autoincrement())
  team_id         Int
  sample_survey_id Int
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  team            Team           @relation(fields: [team_id], references: [id])
  sample_survey   SampleSurvey   @relation(fields: [sample_survey_id], references: [id])
  survey_results  SurveyResult[]

  @@map("team_surveys")
}

model SurveyResult {
  id              Int                @id @default(autoincrement())
  user_id         Int
  team_survey_id  Int
  sample_survey_id Int
  sent_at         DateTime           @default(now()) @db.Timestamptz(6)
  total_score     Int                @db.SmallInt
  is_anon         Boolean            @default(true)
  user            User               @relation(fields: [user_id], references: [id])
  team_survey     TeamSurvey         @relation(fields: [team_survey_id], references: [id])
  sample_survey   SampleSurvey       @relation(fields: [sample_survey_id], references: [id])
  scores          UserSubscaleScore[]

  @@map("survey_results")
}

model Question {
  id          Int                @id @default(autoincrement())
  survey_id   Int
  survey      SampleSurvey       @relation(fields: [survey_id], references: [id])
  choices     Choice[]
  subscales   QuestionSubscale[]

  @@map("questions")
}

model Choice {
  id          Int        @id @default(autoincrement())
  question_id Int
  order_num   Int
  content     String     @db.VarChar(255)
  question    Question   @relation(fields: [question_id], references: [id])

  @@map("choices")
}

model QuestionSubscale {
  question_id  Int
  subscale_id  Int
  question     Question  @relation(fields: [question_id], references: [id])
  subscale     Subscale  @relation(fields: [subscale_id], references: [id])

  @@id([question_id, subscale_id])
  @@map("question_subscales")
}

model NotificationSettings {
  user_id        Int       @id
  notify_via_tg  Boolean   @default(false)
  notify_via_web Boolean   @default(true)
  last_reminded  DateTime? @db.Timestamptz(6)
  user           User      @relation(fields: [user_id], references: [id])

  @@map("notification_settings")
}

model WebPushSubscription {
  user_id     Int      @id
  endpoint    String   @db.Text
  p256dh_key  String   @db.Text
  auth_key    String   @db.Text
  device_name String?  @db.VarChar(255)
  user        User     @relation(fields: [user_id], references: [id])

  @@map("web_push_subscriptions")
}

model Complaint {
  id           Int      @id @default(autoincrement())
  from_user_id Int
  to_user_id   Int
  team_id      Int
  content      String   @db.Text
  is_anon      Boolean  @default(true)
  from_user    User     @relation("from_user", fields: [from_user_id], references: [id])
  to_user      User     @relation("to_user", fields: [to_user_id], references: [id])
  team         Team     @relation(fields: [team_id], references: [id])

  @@map("complaints")
}

model UserSubscaleScore {
  result_id    Int
  subscale_id  Int
  score        Int          @db.SmallInt
  result       SurveyResult @relation(fields: [result_id], references: [id])
  subscale     Subscale     @relation(fields: [subscale_id], references: [id])

  @@id([result_id, subscale_id])
  @@map("user_subscale_scores")
}

enum Role {
  manager
  member
}

model UserTeam {
  user_id   Int
  team_id   Int
  role      Role
  user      User     @relation(fields: [user_id], references: [id])
  team      Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
  @@map("user_teams")
}
