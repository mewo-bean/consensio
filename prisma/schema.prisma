generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int                   @id @default(autoincrement())
  firstName             String?               @map("first_name") @db.VarChar(20)
  lastName              String?               @map("last_name") @db.VarChar(20)
  username              String                @unique @db.VarChar(50)
  email                 String                @unique @db.VarChar(255)
  passwordHash          String                @map("password_hash") @db.VarChar(255)
  tgId                  BigInt?               @map("tg_id")
  surveyResults         SurveyResult[]
  complaintsFrom        Complaint[]           @relation("from_user")
  complaintsTo          Complaint[]           @relation("to_user")
  notificationSettings  NotificationSettings?
  webPushSubscriptions  WebPushSubscription[]
  teams                 UserTeam[]
  telegramLinkTokens    TelegramLinkToken[]
  appFeedbacks  AppFeedback[]

  @@map("users")
}

model Team {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(50)
  inviteCode  String       @unique @map("invite_code") @db.VarChar(10)
  teamSurveys TeamSurvey[]
  complaints  Complaint[]
  members     UserTeam[]

  @@map("teams")
}

model SampleSurvey {
  id            Int            @id @default(autoincrement())
  title         String         @db.VarChar(50)
  teamSurveys   TeamSurvey[]
  surveyResults SurveyResult[]
  questions     Question[]

  @@map("sample_surveys")
}

model Subscale {
  id         Int                 @id @default(autoincrement())
  title      String              @db.VarChar(50)
  topMean    Int                 @map("top_mean") @db.SmallInt
  bottomMean Int                 @map("bottom_mean") @db.SmallInt
  questions  QuestionSubscale[]
  scores     UserSubscaleScore[]

  @@map("subscales")
}

model TeamSurvey {
  id             Int            @id @default(autoincrement())
  teamId         String         @map("team_id")
  sampleSurveyId Int            @map("sample_survey_id")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  team           Team           @relation(fields: [teamId], references: [id])
  sampleSurvey   SampleSurvey   @relation(fields: [sampleSurveyId], references: [id])
  surveyResults  SurveyResult[]

  @@map("team_surveys")
}

model SurveyResult {
  id             Int                 @id @default(autoincrement())
  userId         Int                 @map("user_id")
  teamSurveyId   Int                 @map("team_survey_id")
  sampleSurveyId Int                 @map("sample_survey_id")
  sentAt         DateTime            @default(now()) @map("sent_at") @db.Timestamptz(6)
  totalScore     Int                 @map("total_score") @db.SmallInt
  isAnon         Boolean             @default(true) @map("is_anon")
  user           User                @relation(fields: [userId], references: [id])
  teamSurvey     TeamSurvey          @relation(fields: [teamSurveyId], references: [id])
  sampleSurvey   SampleSurvey        @relation(fields: [sampleSurveyId], references: [id])
  scores         UserSubscaleScore[]

  @@map("survey_results")
}

model Question {
  id        Int                @id @default(autoincrement())
  surveyId  Int                @map("survey_id")
  survey    SampleSurvey       @relation(fields: [surveyId], references: [id])
  choices   Choice[]
  subscales QuestionSubscale[]

  @@map("questions")
}

model Choice {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  orderNum   Int      @map("order_num")
  content    String   @db.VarChar(255)
  question   Question @relation(fields: [questionId], references: [id])

  @@map("choices")
}

model QuestionSubscale {
  questionId Int      @map("question_id")
  subscaleId Int      @map("subscale_id")
  question   Question @relation(fields: [questionId], references: [id])
  subscale   Subscale @relation(fields: [subscaleId], references: [id])

  @@id([questionId, subscaleId])
  @@map("question_subscales")
}

model NotificationSettings {
  userId       Int       @id @map("user_id")
  notifyViaTg  Boolean   @default(false) @map("notify_via_tg")
  notifyViaWeb Boolean   @default(true) @map("notify_via_web")
  lastReminded DateTime? @map("last_reminded") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id])

  @@map("notification_settings")
}

model WebPushSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  endpoint   String   @unique
  p256dhKey  String   @map("p256dh_key")
  authKey    String   @map("auth_key")
  deviceName String?  @map("device_name")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("web_push_subscriptions")
}

model Complaint {
  id         Int     @id @default(autoincrement())
  fromUserId Int     @map("from_user_id")
  toUserId   Int     @map("to_user_id")
  teamId     String  @map("team_id")
  content    String  @db.Text
  isAnon     Boolean @default(true) @map("is_anon")
  fromUser   User    @relation("from_user", fields: [fromUserId], references: [id])
  toUser     User    @relation("to_user", fields: [toUserId], references: [id])
  team       Team    @relation(fields: [teamId], references: [id])

  @@map("complaints")
}

model UserSubscaleScore {
  resultId   Int          @map("result_id")
  subscaleId Int          @map("subscale_id")
  score      Int          @db.SmallInt
  result     SurveyResult @relation(fields: [resultId], references: [id])
  subscale   Subscale     @relation(fields: [subscaleId], references: [id])

  @@id([resultId, subscaleId])
  @@map("user_subscale_scores")
}

enum Role {
  manager
  member
}

model UserTeam {
  userId Int    @map("user_id")
  teamId String @map("team_id")
  role   Role
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@map("user_teams")
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("telegram_link_tokens")
}

model AppFeedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
